#!/usr/bin/env sh
set -eu

PYTHON=""
for candidate in python python3 "py -3"; do
  if $candidate --version >/dev/null 2>&1; then
    PYTHON="$candidate"
    break
  fi
done

if [ -z "$PYTHON" ]; then
  echo "ERROR: Python is required to run ByteTrain git hooks." >&2
  exit 1
fi

$PYTHON scripts/git-hooks/check_commit_msg.py "$1"
