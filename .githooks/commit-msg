#!/usr/bin/env sh
set -eu

if command -v python >/dev/null 2>&1; then
  PYTHON=python
elif command -v python3 >/dev/null 2>&1; then
  PYTHON=python3
elif command -v py >/dev/null 2>&1; then
  PYTHON="py -3"
else
  echo "ERROR: Python is required to run ByteTrain git hooks." >&2
  exit 1
fi

$PYTHON scripts/git-hooks/check_commit_msg.py "$1"
