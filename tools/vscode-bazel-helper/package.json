{
  "name": "bytetrain-vscode-bazel-helper",
  "displayName": "ByteTrain Bazel Helper",
  "description": "Prototype VS Code commands for running ByteTrain IDE build helper targets.",
  "version": "0.0.1",
  "publisher": "bytetrain",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:bytetrain.bazelHelper.buildApp",
    "onCommand:bytetrain.bazelHelper.runApp",
    "onCommand:bytetrain.bazelHelper.assembleDebug",
    "onCommand:bytetrain.bazelHelper.buildProto",
    "onCommand:bytetrain.bazelHelper.buildFeatures",
    "onCommand:bytetrain.bazelHelper.testRustSdk",
    "onCommand:bytetrain.bazelHelper.queryAppDeps",
    "onCommand:bytetrain.bazelHelper.copyDiagnosticContext",
    "onCommand:bytetrain.bazelHelper.openBuildCommands",
    "onCommand:bytetrain.bazelHelper.openModuleBoundaries",
    "onCommand:bytetrain.bazelHelper.openCommonBuildErrors"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bytetrain.bazelHelper.buildApp",
        "title": "Bazel: Build App"
      },
      {
        "command": "bytetrain.bazelHelper.runApp",
        "title": "Bazel: Run App"
      },
      {
        "command": "bytetrain.bazelHelper.assembleDebug",
        "title": "Gradle: Assemble Debug"
      },
      {
        "command": "bytetrain.bazelHelper.buildProto",
        "title": "Bazel: Build Proto"
      },
      {
        "command": "bytetrain.bazelHelper.buildFeatures",
        "title": "Bazel: Build Features"
      },
      {
        "command": "bytetrain.bazelHelper.testRustSdk",
        "title": "Rust: Test SDK"
      },
      {
        "command": "bytetrain.bazelHelper.queryAppDeps",
        "title": "Bazel: Query App Deps"
      },
      {
        "command": "bytetrain.bazelHelper.copyDiagnosticContext",
        "title": "Bazel: Copy Diagnostic Context"
      },
      {
        "command": "bytetrain.bazelHelper.openBuildCommands",
        "title": "Bazel: Open Build Commands"
      },
      {
        "command": "bytetrain.bazelHelper.openModuleBoundaries",
        "title": "Bazel: Open Module Boundaries"
      },
      {
        "command": "bytetrain.bazelHelper.openCommonBuildErrors",
        "title": "Bazel: Open Common Build Errors"
      }
    ]
  }
}
