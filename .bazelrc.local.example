# Copy this file to .bazelrc.local and adjust paths for your machine.
# .bazelrc.local is ignored by Git.

# Optional: use a prewarmed distdir when network downloads are slow.
# common --distdir=<path-to-bazel-distdir>

# Optional: keep external repository downloads in a stable local cache.
# common --repository_cache=<path-to-bazel-repository-cache>

# Optional: Go proxy settings for restricted networks.
# common --repo_env=GOPROXY=https://goproxy.cn,https://proxy.golang.org,direct
# common --repo_env=GOSUMDB=sum.golang.google.cn
